SP_DATABASE_URL=postgresql://postgres@127.0.0.1:5432/scientific_protocol
SP_RPC_URL=http://127.0.0.1:8545
# SP_POSTGRES_PASSWORD=
PORT=3000
# Reference service authority boundary. Containers default to read-only.
SP_SERVICE_MODE=read-only
# Run `scientific-protocol-service migrate` as a release job instead of migrating on API startup.
SP_RUN_MIGRATIONS=false
# Optional base URL used by CLI healthcheck/readiness commands.
# SP_SERVICE_HEALTH_URL=http://127.0.0.1:3000
SP_DEPLOYMENT_PATH=/absolute/path/to/ops/runtime/local.addresses.json
SP_READ_MODEL_PATH=/absolute/path/to/ops/runtime/read-model.json
# Required for remote deployments; choose exactly one. The deployed value is recorded in the
# deployment manifest and becomes the gateway's authorBondWei default.
# SP_MIN_AUTHOR_BOND_ETH=0.005
# SP_MIN_AUTHOR_BOND_WEI=5000000000000000
# Opt-in: write the full read model to SP_READ_MODEL_PATH after each sync.
# Off by default; the snapshot is a debugging artifact, not a serving dependency,
# and it costs a full read-model materialization per sync tick.
# SP_READ_MODEL_SNAPSHOT=true
# SP_PUBLIC_BASE_URL=https://demo.example.com
# SP_PUBLIC_DOMAIN=demo.example.com
# Comma-separated origins allowed to read public JSON config routes such as /write-config.
# This is not write authority.
# SP_PUBLIC_CORS_ORIGINS=https://protocol-preview.example.org
# Optional public wallet/RPC URL exposed by /write-config for non-local chains.
# SP_PUBLIC_RPC_URL=https://sepolia.base.org
# Optional direct wallet submit evidence inputs. These are public tx hashes, not secrets.
# SP_DIRECT_CREATE_CLAIM_TX=0x...
# SP_DIRECT_ADD_ARTIFACT_TX=0x...
# SP_TRUST_PROXY=true
# SP_BIND_HOST=127.0.0.1
# Local default uses a filesystem cache. Shared deployments should prefer ipfs.
SP_ARTIFACT_BACKEND=filesystem
# SP_ARTIFACT_IPFS_PROVIDER=kubo
# SP_ARTIFACT_FILESYSTEM_ROOT=/absolute/path/to/artifact-store
# SP_ARTIFACT_IPFS_API_URL=http://127.0.0.1:5001
# SP_ARTIFACT_IPFS_GATEWAY_URL=http://127.0.0.1:8080/ipfs
# SP_ARTIFACT_IPFS_PIN=true
# SP_ARTIFACT_IPFS_AUTH_HEADER_NAME=Authorization
# SP_ARTIFACT_IPFS_AUTH_HEADER_VALUE=Bearer your-token
# SP_ARTIFACT_IPFS_AUTH_HEADER_VALUE_FILE=/absolute/path/to/ipfs-auth-header-value
# SP_ARTIFACT_IPFS_AUTH_HEADER_VALUE_SECRET_REF=sp-ipfs-auth-header-value:latest
# Pinata preset:
# SP_ARTIFACT_IPFS_PROVIDER=pinata
# SP_ARTIFACT_PINATA_JWT=replace-with-pinata-jwt
# SP_ARTIFACT_PINATA_JWT_FILE=/absolute/path/to/pinata.jwt
# SP_ARTIFACT_PINATA_JWT_SECRET_REF=sp-pinata-jwt:latest
# SP_ARTIFACT_PINATA_API_URL=https://uploads.pinata.cloud
# SP_ARTIFACT_PINATA_GATEWAY_URL=https://your-gateway.mypinata.cloud
# SP_ARTIFACT_PINATA_NETWORK=public
# SP_ARTIFACT_IPFS_REPLICA_TARGETS=[{"replicaKey":"pinata-public","provider":"pinata","pinataJwt":"replace-with-pinata-jwt"},{"replicaKey":"secondary-kubo","apiUrl":"https://your-secondary-ipfs-api.example"}]
# SP_ARTIFACT_GCS_BUCKET=scientific-protocol-artifacts
# SP_ARTIFACT_GCS_PREFIX=dev
# SP_ARTIFACT_HTTP_BASE_URL=http://127.0.0.1:8080/artifacts
# SP_ARTIFACT_S3_BUCKET=scientific-protocol-artifacts
# SP_ARTIFACT_S3_REGION=us-east-1
# SP_ARTIFACT_S3_ENDPOINT=http://127.0.0.1:9000
# SP_ARTIFACT_S3_PREFIX=dev
# SP_ARTIFACT_S3_FORCE_PATH_STYLE=true
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Optional operator keys. Local scripts fall back to deterministic Hardhat accounts.
# SP_PROTOCOL_ADMIN_PRIVATE_KEY=
# SP_CLAIM_AUTHOR_PRIVATE_KEY=
# SP_REPLICATOR_PRIVATE_KEY=
# SP_AGENT_OPERATOR_PRIVATE_KEY=
# SP_REPLICATION_SUBMITTER_PRIVATE_KEY=
# SP_RESOLVER_PRIVATE_KEY=
# SP_CHECKPOINT_PUBLISHER_PRIVATE_KEY=
# SP_OPERATOR_PRIVATE_KEY=
# SP_OPERATOR_PRIVATE_KEY_FILE=/absolute/path/to/operator.key
# SP_OPERATOR_PRIVATE_KEY_SECRET_REF=sp-operator-private-key:latest
# Optional storage attestor key for signed artifact storage attestations.
# SP_STORAGE_ATTESTOR_PRIVATE_KEY=
# SP_STORAGE_ATTESTOR_PRIVATE_KEY_FILE=/absolute/path/to/storage-attestor.key
# SP_STORAGE_ATTESTOR_PRIVATE_KEY_SECRET_REF=sp-storage-attestor-private-key:latest
# Optional Filecoin Onchain Cloud upload wallet. Keep this outside hosted frontend environments.
# SP_FILECOIN_ONCHAIN_CLOUD_PRIVATE_KEY=
# SP_FILECOIN_ONCHAIN_CLOUD_PRIVATE_KEY_FILE=/absolute/path/to/filecoin-onchain-cloud.key
# SP_FILECOIN_CHAIN_ID=314159
# SP_FILECOIN_RPC_URL=
# SP_FILECOIN_COPIES=2
# SP_FILECOIN_WITH_CDN=false

# Optional worker tuning
# SP_INDEXER_BATCH_SIZE=100
# SP_REPLICATION_WORKER_INTERVAL_MS=10000
# SP_REPLICATION_WORKER_ONCE=true
# SP_PUBLIC_RATE_LIMIT_WINDOW_MS=60000
# SP_PUBLIC_RATE_LIMIT_MAX_REQUESTS=20
# SP_ADMIN_RATE_LIMIT_WINDOW_MS=60000
# SP_ADMIN_RATE_LIMIT_MAX_REQUESTS=10

# Optional demo admin token. Required for remote-RPC staging deployments.
# SP_DEMO_ADMIN_TOKEN=
# SP_DEMO_ADMIN_TOKEN_FILE=/absolute/path/to/demo-admin-token
# SP_DEMO_ADMIN_TOKEN_SECRET_REF=sp-demo-admin-token:latest
