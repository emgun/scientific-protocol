    "src/shared/artifact-storage-attestations.ts",
    "src/shared/artifact-storage-bundles.ts",
    "src/shared/artifact-storage-policy.ts",
    "src/shared/contracts.ts",
    "src/shared/deployment.ts",
    "src/shared/secrets.ts",
    "src/shared/sha256.ts"
  ]
}
