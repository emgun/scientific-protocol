  "compilerOptions": {
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationMap": false,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src",
    "sourceMap": false
  },
  "include": [
    "src/generated/contracts.ts",
    "src/sdk/client.ts",
    "src/sdk/index.ts",
    "src/sdk/rewards.ts",
    "src/sdk/types.ts",
