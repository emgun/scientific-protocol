{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scientific-protocol.local/schemas/artifact-storage-bundle.schema.json",
  "title": "ArtifactStorageBundleManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "kind",
    "version",
    "bundleKey",
    "bundleCid",
    "bundleUri",
    "storageRail",
    "generatedAt",
    "manifestDigest",
    "metadata",
    "artifacts"
  ],
  "properties": {
    "kind": {
      "const": "scientific.artifact-storage-bundle"
    },
    "version": {
      "const": 1
    },
    "bundleKey": {
      "type": "string",
      "minLength": 1
    },
    "bundleCid": {
      "type": ["string", "null"]
    },
    "bundleUri": {
      "type": ["string", "null"]
    },
    "storageRail": {
      "type": "string",
      "minLength": 1
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "manifestDigest": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "metadata": {
      "type": "object"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifactKey",
          "byteLength",
          "cid",
          "contentType",
          "durabilityClass",
          "memberPath",
          "metadata",
          "sha256",
          "sourceUri"
        ],
        "properties": {
          "artifactKey": {
            "type": "string",
            "minLength": 1
          },
          "byteLength": {
            "type": "integer",
            "minimum": 0
          },
          "cid": {
            "type": "string",
            "minLength": 1
          },
          "contentType": {
            "type": "string",
            "minLength": 1
          },
          "durabilityClass": {
            "type": "string",
            "enum": ["A", "B", "C", "D"]
          },
          "memberPath": {
            "type": "string",
            "minLength": 1
          },
          "metadata": {
            "type": "object"
          },
          "sha256": {
            "type": "string",
            "pattern": "^[a-f0-9]{64}$"
          },
          "sourceUri": {
            "type": ["string", "null"]
          }
        }
      }
    }
  }
}
